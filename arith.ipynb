    "#division\n",
    "def division(a,b):\n",
    "    if b==0:\n",
    "       print(\"error\")\n",
    "    try:\n",
    "        return a/b\n",
    "    except ZeroDivisionError:\n",
    "        print(\"Error: Division by zero is not allowed\")\n",
    "a=int(input(\"enter the first no:\"))\n",
    "b=int(input(\"enter the first no:\")) \n",
    "print(\"result:\",division(a,b))\n",
    " "
